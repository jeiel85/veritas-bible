{
  "translation": "KRV",
  "books": [
    {
      "name": "창세기",
      "verses": [
        {"chapter": 1, "verse": 1, "text": "태초에 하나님이 천지를 창조하시니라"},
        {"chapter": 1, "verse": 2, "text": "땅이 혼돈하고 공허하며 흑암이 깊음 위에 있고 하나님의 신은 수면에 운행하시니라"},
        {"chapter": 1, "verse": 3, "text": "하나님이 가라사대 빛이 있으라 하시매 빛이 있었고"},
        {"chapter": 2, "verse": 1, "text": "천지와 만물이 다 이루니라"},
        {"chapter": 2, "verse": 2, "text": "하나님의 지으시던 일이 일곱째 날이 이를 때에 마치니 그 지으시던 일이 다하므로 일곱째 날에 안식하시니라"}
      ]
    },
    {
      "name": "출애굽기",
      "verses": [
        {"chapter": 1, "verse": 1, "text": "야곱과 함께 각각 자기 권속을 데리고 애굽에 이른 이스라엘 아들들의 이름은 이러하니"},
        {"chapter": 1, "verse": 2, "text": "르우벤과 시므온과 레위와 유다와"}
      ]
    }
  ]
}